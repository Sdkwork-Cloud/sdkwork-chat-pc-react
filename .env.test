# Test environment
VITE_APP_ENV=test
VITE_APP_NAME=OpenChat (Test)
VITE_APP_VERSION=1.0.0-test
VITE_DEBUG=true
VITE_LOG_LEVEL=info

# SDKWork API (required by SDK integration)
VITE_API_BASE_URL=https://api-dev.sdkwork.com
VITE_ACCESS_TOKEN=replace-with-test-access-token

# Backward-compatible aliases for existing modules
VITE_APP_API_BASE_URL=https://api-dev.sdkwork.com

# IM / RTC
VITE_IM_WS_URL=wss://im-test.openchat.example.com/ws
VITE_APP_IM_WS_URL=wss://im-test.openchat.example.com/ws
VITE_RTC_APP_ID=your-test-app-id
VITE_RTC_PROVIDER=volcengine


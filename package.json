{
  "name": "openchat-react-pc",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --mode development",
    "dev:test": "vite --mode test",
    "dev:prod": "vite --mode production",
    "dev:desktop": "tauri dev",
    "build": "tsc && vite build --mode production",
    "build:dev": "tsc && vite build --mode development",
    "build:test": "tsc && vite build --mode test",
    "build:prod": "tsc && vite build --mode production",
    "build:desktop": "tauri build",
    "preview": "vite preview",
    "preview:test": "vite preview --mode test",
    "preview:prod": "vite preview --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:packages": "pnpm -r --workspace-concurrency=1 --if-present run typecheck",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:packages",
    "sync:workspace-deps": "node scripts/sync-workspace-deps.mjs",
    "verify:packages": "node scripts/verify-packages.mjs",
    "audit:services": "node scripts/audit-service-standards.mjs",
    "report:services": "node scripts/report-service-conformance.mjs",
    "report:modules": "node scripts/report-module-readiness.mjs",
    "check:sdk-standard": "node ../scripts/check-sdk-compliance.mjs --strict && node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs",
    "check:sdk-standard:quick": "node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs",
    "scaffold:package": "node scripts/scaffold-package.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "tauri": "tauri"
  },
  "dependencies": {
    "@sdkwork/app-sdk": "workspace:*",
    "@sdkwork/openchat-pc-i18n": "workspace:*",
    "@openchat/typescript-sdk": "file:./vendor/openchat-typescript-sdk",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^1.5.0",
    "@tiptap/extension-bubble-menu": "^3.18.0",
    "@tiptap/extension-code-block-lowlight": "^3.18.0",
    "@tiptap/extension-floating-menu": "^3.18.0",
    "@tiptap/extension-mention": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@types/dompurify": "^3.0.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "blurhash": "^2.0.5",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "dompurify": "^3.3.1",
    "easyjssdk": "^1.0.15",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.3",
    "lodash-es": "^4.17.23",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.1.0",
    "web-vitals": "^5.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tauri-apps/cli": "^1.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.3.6",
    "terser": "^5.46.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-compression2": "^2.4.0",
    "vitest": "^4.0.18"
  }
}

# Production environment
VITE_APP_ENV=production
VITE_APP_NAME=OpenChat
VITE_APP_VERSION=1.0.0
VITE_DEBUG=false
VITE_LOG_LEVEL=error

# SDKWork API (required by SDK integration)
VITE_API_BASE_URL=https://api.sdkwork.com
VITE_ACCESS_TOKEN=replace-with-production-access-token

# Backward-compatible aliases for existing modules
VITE_APP_API_BASE_URL=https://api.sdkwork.com

# IM / RTC
VITE_IM_WS_URL=wss://im.openchat.example.com/ws
VITE_APP_IM_WS_URL=wss://im.openchat.example.com/ws
VITE_RTC_APP_ID=your-production-app-id
VITE_RTC_PROVIDER=volcengine


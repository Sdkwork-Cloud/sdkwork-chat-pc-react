# Copy this file to one of:
# - .env.development
# - .env.test
# - .env.production
#
# Tracked workspace defaults:
# - development => https://api-dev.sdkwork.com
# - test        => https://api-test.sdkwork.com
# - production  => https://api.sdkwork.com

VITE_APP_ENV="development"
VITE_API_BASE_URL="https://api-dev.sdkwork.com"
VITE_APP_API_BASE_URL="https://api-dev.sdkwork.com"
VITE_TIMEOUT="30000"
VITE_API_KEY=""
VITE_ACCESS_TOKEN=""
VITE_TENANT_ID=""
VITE_ORGANIZATION_ID=""
VITE_PLATFORM="desktop"
VITE_APP_ID="10001"
VITE_RELEASE_CHANNEL="stable"
VITE_DISTRIBUTION_ID="global"
VITE_ENABLE_STARTUP_UPDATE_CHECK="true"
SDKWORK_API_BASE_URL="https://api-dev.sdkwork.com"
SDKWORK_ACCESS_TOKEN=""
SDKWORK_TENANT_ID=""
SDKWORK_ORGANIZATION_ID=""
SDKWORK_PLATFORM="desktop"
VITE_IM_WS_URL="ws://localhost:5200"
VITE_APP_IM_WS_URL="ws://localhost:5200"
VITE_RTC_APP_ID=""
VITE_RTC_PROVIDER="volcengine"
